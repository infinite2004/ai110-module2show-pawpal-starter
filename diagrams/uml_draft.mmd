classDiagram
    class Owner {
        +string name
        +list pets
        +add_pet(Pet pet)
        +get_pets() list
        +get_all_tasks() list
    }

    class Pet {
        +string name
        +string species
        +int age
        +list tasks
        +add_task(Task task)
        +get_tasks() list
    }

    class Task {
        +string description
        +string time
        +string frequency
        +bool completed
        +mark_complete()
        +mark_incomplete()
        +display_status() string
    }

    class Scheduler {
        +Owner owner
        +get_todays_tasks() list
        +sort_tasks_by_time(list tasks) list
        +build_schedule() list
        +format_schedule() string
    }

    Owner "1" --> "1..*" Pet : cares for
    Pet "1" --> "0..*" Task : has tasks
    Scheduler --> Owner : retrieves tasks from
    Scheduler --> Task : organizes
